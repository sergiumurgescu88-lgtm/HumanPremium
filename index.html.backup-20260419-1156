<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VibeBuddy — AI care construiește</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #080808;
  --bg2: #101010;
  --bg3: #161616;
  --green: #00e87a;
  --green-dim: rgba(0,232,122,0.12);
  --yellow: #f5a623;
  --yellow-dim: rgba(245,166,35,0.12);
  --red: #ef4444;
  --purple: #a78bfa;
  --blue: #38bdf8;
  --teal: #2dd4bf;
  --amber: #fbbf24;
  --text: #ffffff;
  --text2: rgba(255,255,255,0.65);
  --text3: rgba(255,255,255,0.4);
  --border: rgba(255,255,255,0.08);
  --border2: rgba(255,255,255,0.12);
  --card: rgba(255,255,255,0.04);
  --card-hover: rgba(255,255,255,0.07);
  --radius: 16px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Figtree',sans-serif;font-size:16px;line-height:1.6;overflow-x:hidden}
a{text-decoration:none;color:inherit}
img{max-width:100%}

/* ── NAV ── */
nav{position:sticky;top:0;z-index:100;background:rgba(8,8,8,0.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:0 2rem}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;height:64px;gap:2rem}
.nav-logo{font-family:'Figtree',sans-serif;font-size:1.25rem;font-weight:800;color:var(--text);white-space:nowrap}
.nav-logo span{color:var(--green)}
.nav-links{display:flex;gap:1.5rem;flex:1;justify-content:center}
.nav-links a{font-size:0.85rem;font-weight:500;color:var(--text2);transition:color .2s}
.nav-links a:hover{color:var(--text)}
.nav-links a.back{color:var(--text3);font-size:0.8rem}
.nav-ctas{display:flex;gap:0.75rem;align-items:center;white-space:nowrap}
.btn-sergiu{display:flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.06);border:1px solid var(--border2);color:var(--text);font-size:0.85rem;font-weight:600;padding:0.5rem 1rem;border-radius:8px;cursor:pointer;transition:all .2s}
.btn-sergiu::before{content:'';width:8px;height:8px;border-radius:50%;background:var(--green);flex-shrink:0;animation:pulse 2s infinite}
.btn-sergiu:hover{background:rgba(255,255,255,0.1)}
.btn-buy{background:var(--green);color:#000;font-size:0.85rem;font-weight:700;padding:0.5rem 1.25rem;border-radius:8px;cursor:pointer;transition:all .2s;border:none}
.btn-buy:hover{background:#00ff88;transform:translateY(-1px)}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.3)}}

/* ── SECTIONS ── */
section{padding:5rem 2rem}
.container{max-width:1200px;margin:0 auto}
.section-badge{display:inline-flex;align-items:center;gap:0.5rem;font-size:0.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:1.5rem}
.section-badge::after{content:'';display:block;width:40px;height:1px;background:var(--border2)}
.badge-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}

/* ── HERO ── */
#hero{padding:6rem 2rem 4rem;text-align:center}
.hero-pill{display:inline-flex;align-items:center;gap:0.5rem;border:1px solid var(--border2);border-radius:100px;padding:0.35rem 1rem;font-size:0.75rem;font-weight:600;color:var(--text2);letter-spacing:.05em;margin-bottom:2.5rem}
.hero-pill::before{content:'●';color:var(--green);font-size:0.6rem}
h1.hero-h1{font-family:'Plus Jakarta Sans',sans-serif;font-size:clamp(2.5rem,6vw,4.5rem);font-weight:800;line-height:1.1;letter-spacing:-.02em;margin-bottom:1.5rem}
h1.hero-h1 .accent{color:var(--green)}
.hero-desc{font-size:clamp(1rem,2vw,1.15rem);color:var(--text2);max-width:640px;margin:0 auto 2rem;line-height:1.65}
.hero-desc strong{color:var(--text);font-weight:700}
.hero-terminal{background:#0d1117;border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:1rem 1.5rem;max-width:480px;margin:0 auto 2.5rem;text-align:left;font-family:'Courier New',monospace;font-size:0.875rem;color:var(--green)}
.hero-terminal span.cursor{display:inline-block;width:2px;height:1em;background:var(--green);animation:blink 1s infinite;vertical-align:middle;margin-left:2px}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
.hero-btns{display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:center;margin-bottom:3rem}
.btn-primary{background:var(--green);color:#000;font-family:'Figtree',sans-serif;font-size:0.95rem;font-weight:700;padding:.8rem 1.75rem;border-radius:10px;border:none;cursor:pointer;transition:all .25s;white-space:nowrap}
.btn-primary:hover{background:#00ff88;transform:translateY(-2px);box-shadow:0 8px 30px rgba(0,232,122,.3)}
.btn-secondary{background:var(--yellow);color:#000;font-family:'Figtree',sans-serif;font-size:0.95rem;font-weight:700;padding:.8rem 1.75rem;border-radius:10px;border:none;cursor:pointer;transition:all .25s;white-space:nowrap;display:flex;align-items:center;gap:.5rem}
.btn-secondary:hover{background:#ffc14d;transform:translateY(-2px);box-shadow:0 8px 30px rgba(245,166,35,.3)}
.btn-ghost{background:rgba(255,255,255,0.06);color:var(--text);font-family:'Figtree',sans-serif;font-size:0.95rem;font-weight:600;padding:.8rem 1.75rem;border-radius:10px;border:1px solid var(--border2);cursor:pointer;transition:all .25s;white-space:nowrap;display:flex;align-items:center;gap:.5rem}
.btn-ghost:hover{background:rgba(255,255,255,.1)}
.btn-ghost::before{content:'💬';font-size:1rem}
.hero-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:14px;overflow:hidden;max-width:700px;margin:0 auto}
.stat-item{background:var(--bg2);padding:1.25rem 1rem;text-align:center}
.stat-num{font-family:'Plus Jakarta Sans',sans-serif;font-size:1.75rem;font-weight:800;color:var(--green);line-height:1}
.stat-num.yellow{color:var(--yellow)}
.stat-num.purple{color:var(--purple)}
.stat-label{font-size:0.7rem;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-top:.3rem}

/* ── PLATFORM ── */
#platform{background:var(--bg)}
.platform-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:3rem}
.pstat{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;text-align:center;transition:all .25s;cursor:default}
.pstat:hover{border-color:rgba(0,232,122,.3);background:var(--card-hover)}
.pstat-num{font-family:'Plus Jakarta Sans',sans-serif;font-size:2.5rem;font-weight:800;line-height:1;margin-bottom:.3rem}
.pstat-num.green{color:var(--green)}
.pstat-num.yellow{color:var(--yellow)}
.pstat-num.purple{color:var(--purple)}
.pstat-num.blue{color:var(--blue)}
.pstat-label{font-size:0.8rem;color:var(--text3);font-weight:500}

/* Flow diagram */
.flow-container{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:2rem;margin-bottom:1rem}
.flow-steps{display:flex;align-items:center;gap:0;overflow-x:auto;padding-bottom:.5rem}
.flow-step{display:flex;flex-direction:column;align-items:center;gap:.5rem;flex-shrink:0;cursor:pointer;padding:0 .5rem;transition:all .2s}
.flow-step:hover .flow-circle{transform:scale(1.1)}
.flow-arrow{color:var(--text3);font-size:1.2rem;flex-shrink:0;margin:0 .25rem;padding-bottom:1.5rem}
.flow-circle{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;color:#fff;transition:all .25s;border:2px solid transparent}
.flow-circle.c0{background:#1a1a2e;border-color:#555;color:var(--text3);font-size:.7rem}
.flow-circle.c1{background:linear-gradient(135deg,#1e40af,#3b82f6)}
.flow-circle.c2{background:linear-gradient(135deg,#166534,#22c55e)}
.flow-circle.c3{background:linear-gradient(135deg,#92400e,#f59e0b)}
.flow-circle.c4{background:linear-gradient(135deg,#581c87,#a855f7)}
.flow-circle.c5{background:linear-gradient(135deg,#991b1b,#ef4444)}
.flow-step.active .flow-circle{box-shadow:0 0 20px currentColor;transform:scale(1.15)}
.flow-label{font-size:.7rem;font-weight:600;color:var(--text3);text-align:center;max-width:60px}
.flow-hint{text-align:center;font-size:.8rem;color:var(--text3);margin-top:.75rem}

/* Module cards */
.modules{display:flex;flex-direction:column;gap:.75rem;margin-top:1.5rem}
.module-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:all .25s;cursor:pointer}
.module-card:hover{border-color:var(--border2);background:var(--card-hover)}
.module-card.open{border-color:rgba(0,232,122,.25)}
.module-header{display:flex;align-items:center;gap:1rem;padding:1.25rem 1.5rem}
.module-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
.module-info{flex:1}
.module-title{font-weight:700;font-size:1rem;color:var(--text)}
.module-sub{font-size:.8rem;color:var(--text3);margin-top:.1rem}
.module-toggle{font-size:.8rem;color:var(--text3);background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:6px;padding:.25rem .75rem;font-family:'Figtree',sans-serif;cursor:pointer;transition:all .2s;white-space:nowrap}
.module-card.open .module-toggle{color:var(--green);border-color:rgba(0,232,122,.3)}
.module-body{display:none;padding:0 1.5rem 1.5rem;border-top:1px solid var(--border)}
.module-body p{font-size:.9rem;color:var(--text2);line-height:1.65;margin:.75rem 0}
.module-card.open .module-body{display:block}
.module-tags{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.75rem}
.tag{background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:6px;padding:.2rem .65rem;font-size:.75rem;color:var(--text2);font-weight:500}
.module-grid{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-top:.75rem}
.mini-card{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;padding:.875rem}
.mini-card-title{font-weight:700;font-size:.875rem;color:var(--text);margin-bottom:.25rem}
.mini-card-desc{font-size:.8rem;color:var(--text3)}

/* ── VIBECODDING ── */
#vibecodding{background:var(--bg2)}
.vibecodding-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start}
.code-editor{background:#0d1117;border:1px solid rgba(255,255,255,.12);border-radius:14px;overflow:hidden}
.code-titlebar{display:flex;align-items:center;gap:.5rem;padding:.75rem 1rem;background:#161b22;border-bottom:1px solid rgba(255,255,255,.08)}
.dot{width:12px;height:12px;border-radius:50%}
.dot.red{background:#ff5f56}
.dot.yellow{background:#ffbd2e}
.dot.green{background:#27c93f}
.code-filename{font-size:.75rem;color:var(--text3);margin-left:.5rem;font-family:monospace}
.code-body{padding:1.5rem;font-family:'Courier New',monospace;font-size:.8rem;line-height:1.7}
.ln{display:block;color:var(--text3)}
.ln .lnum{color:#444;display:inline-block;width:20px;margin-right:12px;text-align:right;user-select:none}
.ln .comment{color:#8b949e}
.ln .keyword{color:#ff7b72}
.ln .string{color:#a5d6ff}
.ln .fn{color:#d2a8ff}
.ln .cls{color:#ffa657}
.ln .self{color:#79c0ff}
.vibecodding-features{display:flex;flex-direction:column;gap:1rem}
.vf-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;transition:all .25s;cursor:pointer;position:relative;overflow:hidden}
.vf-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at var(--mx,50%) var(--my,50%),rgba(0,232,122,.08),transparent 60%);opacity:0;transition:opacity .3s}
.vf-card:hover::before{opacity:1}
.vf-card:hover{border-color:rgba(0,232,122,.2);transform:translateY(-2px)}
.vf-header{display:flex;align-items:center;gap:.75rem;margin-bottom:.5rem}
.vf-icon{font-size:1.1rem}
.vf-title{font-weight:700;font-size:1rem;color:var(--text)}
.vf-badge{font-size:.65rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:.2rem .6rem;border-radius:4px;margin-left:auto}
.vf-badge.core{background:rgba(0,232,122,.15);color:var(--green)}
.vf-badge.codex{background:rgba(99,102,241,.15);color:#818cf8}
.vf-badge.live{background:rgba(239,68,68,.15);color:#f87171}
.vf-desc{font-size:.875rem;color:var(--text2);line-height:1.55}

/* ── MODELS ── */
#models{background:var(--bg)}
.models-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
.model-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.75rem;transition:all .25s;cursor:pointer;position:relative;overflow:hidden}
.model-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at var(--mx,50%) var(--my,50%),var(--glow,rgba(0,232,122,.1)),transparent 60%);opacity:0;transition:opacity .3s}
.model-card:hover::before{opacity:1}
.model-card:hover{transform:translateY(-3px);box-shadow:0 12px 40px rgba(0,0,0,.5)}
.model-badge{display:inline-block;font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.25rem .75rem;border-radius:6px;margin-bottom:.75rem}
.model-badge.flagship{background:rgba(167,139,250,.15);color:var(--purple)}
.model-badge.coding{background:rgba(56,189,248,.15);color:var(--blue)}
.model-badge.multimodal{background:rgba(45,212,191,.15);color:var(--teal)}
.model-badge.live-data{background:rgba(251,191,36,.15);color:var(--amber)}
.model-title{font-family:'Plus Jakarta Sans',sans-serif;font-size:1.3rem;font-weight:800;margin-bottom:.25rem}
.model-title.purple{color:var(--purple)}
.model-title.blue{color:var(--blue)}
.model-title.teal{color:var(--teal)}
.model-title.amber{color:var(--amber)}
.model-sub{font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:1rem}
.model-desc{font-size:.875rem;color:var(--text2);line-height:1.6;margin-bottom:1.25rem}
.model-uses-label{font-size:.7rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin-bottom:.5rem}
.model-tags{display:flex;flex-wrap:wrap;gap:.4rem}
.model-tag{background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:6px;padding:.2rem .6rem;font-size:.75rem;color:var(--text2)}

/* ── MODES ── */
#modes{background:var(--bg2)}
.modes-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem}
.mode-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;transition:all .25s;cursor:pointer;position:relative;overflow:hidden}
.mode-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at var(--mx,50%) var(--my,50%),var(--glow),transparent 65%);opacity:0;transition:opacity .3s}
.mode-card:hover::before{opacity:1}
.mode-card:hover{transform:translateY(-3px);border-color:var(--border2)}
.mode-dot{width:32px;height:32px;border-radius:50%;margin-bottom:1rem;font-size:1rem;display:flex;align-items:center;justify-content:center}
.mode-title{font-weight:800;font-size:1rem;color:var(--text);margin-bottom:.25rem}
.mode-engines{font-size:.7rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin-bottom:.75rem}
.mode-desc{font-size:.85rem;color:var(--text2);line-height:1.55;margin-bottom:.875rem}
.mode-tags{display:flex;flex-wrap:wrap;gap:.4rem}
.mode-tag{background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:5px;padding:.15rem .55rem;font-size:.7rem;color:var(--text3)}

/* ── COMPARISON ── */
#comparison{background:var(--bg)}
.comp-table{width:100%;border-collapse:collapse;margin-top:2rem}
.comp-table th{padding:.875rem 1rem;text-align:center;font-size:.8rem;font-weight:700;border-bottom:1px solid var(--border)}
.comp-table th:first-child{text-align:left}
.comp-table th.vb{color:var(--green);background:rgba(0,232,122,.05)}
.comp-table td{padding:.875rem 1rem;text-align:center;font-size:.875rem;color:var(--text2);border-bottom:1px solid rgba(255,255,255,.04)}
.comp-table td:first-child{text-align:left;color:var(--text);font-weight:500}
.comp-table td.vb{background:rgba(0,232,122,.04);color:var(--green);font-weight:700}
.comp-table tr:hover td{background:rgba(255,255,255,.02)}
.check{color:var(--green);font-weight:700}
.cross{color:var(--text3)}
.partial{color:var(--yellow)}

/* ── PRICING ── */
#pricing{background:var(--bg2)}
.pricing-wrap{max-width:560px;margin:0 auto}
.pricing-card{background:var(--bg3);border:1px solid var(--border2);border-radius:20px;padding:2.5rem;position:relative;overflow:hidden}
.pricing-card::before{content:'';position:absolute;top:-60px;right:-60px;width:200px;height:200px;background:radial-gradient(circle,rgba(0,232,122,.12),transparent 70%);pointer-events:none}
.pricing-header{text-align:center;margin-bottom:2rem}
.pricing-badge{display:inline-block;font-size:.75rem;font-weight:700;color:var(--green);letter-spacing:.08em;text-transform:uppercase;margin-bottom:.75rem}
.pricing-badge::before{content:'●  ';font-size:.5rem}
.pricing-title{font-size:.9rem;color:var(--text2);margin-bottom.5rem:}
.price-num{font-family:'Plus Jakarta Sans',sans-serif;font-size:5rem;font-weight:800;color:var(--green);line-height:1}
.price-num sup{font-size:2rem;vertical-align:super}
.price-period{font-size:.85rem;color:var(--text3);margin-top:.25rem}
.pricing-features{display:flex;flex-direction:column;gap:.65rem;margin-bottom:2rem}
.pf-item{display:flex;align-items:flex-start;gap:.75rem;font-size:.9rem;color:var(--text2)}
.pf-check{color:var(--green);font-weight:700;flex-shrink:0;margin-top:.1rem}
.pricing-comparison{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:12px;padding:1.25rem;margin-bottom:2rem}
.pc-label{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);text-align:center;margin-bottom:1rem}
.pc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.5rem}
.pc-item{text-align:center}
.pc-name{font-size:.65rem;font-weight:600;color:var(--text3);margin-bottom:.25rem}
.pc-desc{font-size:.6rem;color:var(--text3);line-height:1.3;margin-bottom:.25rem}
.pc-price{font-weight:800;font-size:.9rem}
.pc-price.grok{color:var(--purple)}
.pc-price.gpt{color:var(--teal)}
.pc-price.claude{color:var(--blue)}
.pc-price.vb{color:var(--green);font-size:1.1rem}
.pc-savings{text-align:center;font-size:.8rem;color:var(--green);font-weight:600;margin-top:.75rem}
.pricing-btns{display:flex;flex-direction:column;gap:.75rem}
.btn-pricing-main{background:var(--green);color:#000;font-family:'Figtree',sans-serif;font-size:1rem;font-weight:800;padding:1rem;border-radius:12px;border:none;cursor:pointer;transition:all .25s;width:100%;text-align:center}
.btn-pricing-main:hover{background:#00ff88;transform:translateY(-2px);box-shadow:0 10px 40px rgba(0,232,122,.3)}
.btn-pricing-sec{background:var(--yellow);color:#000;font-family:'Figtree',sans-serif;font-size:1rem;font-weight:800;padding:1rem;border-radius:12px;border:none;cursor:pointer;transition:all .25s;width:100%;text-align:center;display:flex;align-items:center;justify-content:center;gap:.5rem}
.btn-pricing-sec:hover{background:#ffc14d;transform:translateY(-2px)}
.pricing-note{text-align:center;font-size:.75rem;color:var(--text3);margin-top:.75rem}
.pricing-note a{color:var(--text3);text-decoration:underline}

/* ── FAQ ── */
#faq{background:var(--bg)}
.faq-list{max-width:720px;margin:2rem auto 0;display:flex;flex-direction:column;gap:.75rem}
.faq-item{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:border-color .2s}
.faq-item.open{border-color:rgba(0,232,122,.2)}
.faq-q{display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;cursor:pointer;font-weight:600;font-size:.95rem;gap:1rem}
.faq-icon{font-size:1.2rem;color:var(--text3);transition:transform .3s;flex-shrink:0}
.faq-item.open .faq-icon{transform:rotate(45deg);color:var(--green)}
.faq-a{display:none;padding:0 1.5rem 1.5rem;font-size:.9rem;color:var(--text2);line-height:1.65;border-top:1px solid var(--border)}
.faq-a p{margin-top:.75rem}
