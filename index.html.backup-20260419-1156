<script>
// ── TYPING ANIMATION ──
const phrases = [
  '> Transcriu comanda ta vocală și o execut...',
  '> Generez FastAPI cu auth JWT în 30 secunde...',
  '> Scrapper async + rotație proxy configurat...',
  '> Deploy pe VPS cu nginx + SSL automat...',
  '> Agent AI cu memorie persistentă gata...'
];
let pi = 0, ci = 0, deleting = false;
const el = document.getElementById('typed-text');
function type() {
  const phrase = phrases[pi];
  if (!deleting) {
    el.textContent = phrase.slice(0, ++ci);
    if (ci === phrase.length) { deleting = true; setTimeout(type, 2000); return; }
  } else {
    el.textContent = phrase.slice(0, --ci);
    if (ci === 0) { deleting = false; pi = (pi + 1) % phrases.length; }
  }
  setTimeout(type, deleting ? 30 : 55);
}
type();

// ── FLOW STEPS ──
function selectStep(n) {
  document.querySelectorAll('.flow-step').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.flow-step')[n].classList.add('active');
  const modId = 'mod-' + n;
  const mod = document.getElementById(modId);
  if (mod) {
    mod.classList.add('open');
    mod.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
}

// ── MODULE TOGGLE ──
function toggleModule(id) {
  const card = document.getElementById(id);
  const isOpen = card.classList.contains('open');
  document.querySelectorAll('.module-card').forEach(c => c.classList.remove('open'));
  if (!isOpen) card.classList.add('open');
}

// ── FAQ TOGGLE ──
function toggleFaq(item) {
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

// ── MOUSE GLOW ON CARDS ──
document.querySelectorAll('.vf-card, .model-card, .mode-card').forEach(card => {
  card.addEventListener('mousemove', e => {
    const r = card.getBoundingClientRect();
    card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
    card.style.setProperty('--my', ((e.clientY - r.top)  / r.height * 100) + '%');
  });
});

// ── SCROLL REVEAL ──
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.style.opacity = '1';
      e.target.style.transform = 'translateY(0)';
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.model-card, .mode-card, .pstat, .vf-card').forEach(el => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(20px)';
  el.style.transition = 'opacity .5s ease, transform .5s ease';
  observer.observe(el);
});
</script>

