const fs = require("fs");

const MEMORY_FILE = path.join(__dirname, "memory", "buddy_memory.json");

function loadMemory() {
  try {
    return JSON.parse(fs.readFileSync(MEMORY_FILE, "utf8"));
  } catch {
    return {};
  }
}


const SIDE_FILE = path.join(__dirname, "memory", "side_hustle_intelligence.json");

function loadSideIntel() {
  try {
    return JSON.parse(fs.readFileSync(SIDE_FILE, "utf8"));
  } catch {
    return {
      restaurant_funnel_ideas: [],
      ai_agency_offers: [],
      saas_ideas: [],
      template_businesses: [],
      clone_businesses: [],
      automation_agency: [],
      performance_scores: {}
    };
  }
}

function saveSideIntel(data) {
  fs.writeFileSync(SIDE_FILE, JSON.stringify(data, null, 2));
}

function improveSideHustle(prompt, response, specialist) {
  const intel = loadSideIntel();
  const text = (prompt + " " + response).toLowerCase();

  const patterns = {
    restaurant: "restaurant_funnel_ideas",
    funnel: "restaurant_funnel_ideas",
    agency: "ai_agency_offers",
    saas: "saas_ideas",
    template: "template_businesses",
    clone: "clone_businesses",
    automation: "automation_agency"
  };

  for (const key in patterns) {
    if (text.includes(key)) {
      const bucket = patterns[key];
      intel[bucket].push({
        specialist,
        prompt: prompt.slice(0, 200),
        score: 1,
        createdAt: Date.now()
      });

      if (intel[bucket].length > 50) {
        intel[bucket].shift();
      }
    }
  }

  saveSideIntel(intel);
}

function saveMemory(memory) {
  fs.writeFileSync(MEMORY_FILE, JSON.stringify(memory, null, 2));
}

function improveBuddy(mode, specialist, prompt, response) {
  const memory = loadMemory();

  if (!memory[mode]) memory[mode] = {};
  if (!memory[mode][specialist]) {
    memory[mode][specialist] = {
      count: 0,
      bestPrompts: [],
      bestPatterns: []
    };
  }

  memory[mode][specialist].count += 1;
  memory[mode][specialist].bestPrompts.push(prompt.slice(0, 300));

  if (memory[mode][specialist].bestPrompts.length > 20) {
    memory[mode][specialist].bestPrompts.shift();
  }

  saveMemory(memory);
}



