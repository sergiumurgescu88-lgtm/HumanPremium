export async function runBuddy(input: string, options: any = {}): Promise<BuddyResponse> {
  const text = input.toLowerCase();
  let guidance = "Sunt Buddy PREMIUM — AI Executive Companion. Spune-mi ce vrei să construiești, să automatizezi sau să instalezi.";
  let codeSnippet = "";
  let installSteps: string[] = [];
  let productInfo = null;
  let mode = "general";

  // Detect product requests
  for (const [key, product] of Object.entries(daeurosystemKnowledge.products)) {
    if (text.includes(key) || text.includes(product.name.toLowerCase())) {
      productInfo = product;
      mode = key;
      
      if (text.includes("instal") || text.includes("setup") || text.includes("cum instalez")) {
        guidance = `Îți dau pașii exacți de instalare pentru ${product.name} (${product.price}$).`;
        installSteps = [
          `1. Rulează comanda: ${daeurosystemKnowledge.codingTemplates.install}`,
          "2. Configurează variabilele de mediu (.env)",
          "3. Rulează `npm run setup`",
          "4. Verifică cu `pm2 status`"
        ];
      }
      break;
    }
  }

  // Coding requests
  if (text.includes("cod") || text.includes("code") || text.includes("script") || text.includes("api")) {
    mode = "coding";
    guidance = "Iată un exemplu de cod optimizat pentru cerința ta:";
    codeSnippet = daeurosystemKnowledge.codingTemplates.api;
  }

  return {
    mode,
    guidance,
    codeSnippet,
    installSteps,
    productInfo,
    confidence: 0.92
  };
}

